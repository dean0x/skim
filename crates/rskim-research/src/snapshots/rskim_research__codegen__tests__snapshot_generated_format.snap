//! Empirical character bigram IDF weight table for rskim-search sparse index.
//! Generated by rskim-research from data/bigram_weights.json
//!
//! Version: 1  |  Generated: unix:0
//! Corpus: 10 files, 5 unique bigrams
//!
//! DO NOT EDIT MANUALLY — re-run `rskim-research codegen` to regenerate.

#![allow(clippy::excessive_precision)]

/// Sorted (bigram_key, idf_weight) pairs.
///
/// The table is sorted ascending by bigram key, enabling O(log n) binary search.
/// Each bigram key encodes two bytes: `key = (byte1 << 8) | byte2`.
pub const BIGRAM_WEIGHTS: &[(u16, f32)] = &[
    (0x666E, 8.500000_f32), // "fn"
    (0x696D, 6.200000_f32), // "im"
];

/// Default weight for bigrams not in the table.
pub const DEFAULT_WEIGHT: f32 = 1.0;

/// Look up the IDF weight of a bigram by binary search.
///
/// Returns `None` if the bigram is absent from the table.
#[must_use]
pub fn bigram_weight(bigram: u16) -> Option<f32> {
    BIGRAM_WEIGHTS
        .binary_search_by_key(&bigram, |&(k, _)| k)
        .ok()
        .map(|idx| BIGRAM_WEIGHTS[idx].1)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn table_is_sorted_ascending() {
        let keys: Vec<u16> = BIGRAM_WEIGHTS.iter().map(|&(k, _)| k).collect();
        let mut sorted = keys.clone();
        sorted.sort();
        assert_eq!(keys, sorted, "BIGRAM_WEIGHTS must be sorted ascending");
    }

    #[test]
    fn no_duplicate_keys() {
        let keys: Vec<u16> = BIGRAM_WEIGHTS.iter().map(|&(k, _)| k).collect();
        let unique: std::collections::HashSet<u16> = keys.iter().copied().collect();
        assert_eq!(keys.len(), unique.len(), "BIGRAM_WEIGHTS must not have duplicate keys");
    }

    #[test]
    fn bigram_weight_lookup_works() {
        // If the table is non-empty, the first entry must be findable.
        if let Some(&(key, idf)) = BIGRAM_WEIGHTS.first() {
            assert_eq!(bigram_weight(key), Some(idf));
        }
    }

    #[test]
    fn default_weight_is_positive() {
        const { assert!(DEFAULT_WEIGHT > 0.0) };
    }
}
