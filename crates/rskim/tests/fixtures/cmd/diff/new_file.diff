+import { z } from "zod";
+
+export function validate<T>(schema: z.Schema<T>, data: unknown): T {
+  return schema.parse(data);
+}
+
+export const UserSchema = z.object({
+  name: z.string().min(1),
+  email: z.string().email(),
+  age: z.number().int().positive().optional(),
+});
+
